# Django
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,openhim.local
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:8080,http://openhim.local:8080
ENABLE_HEALTH_DEPENDENCY_CHECKS=true
MEDIATOR_MODE=hybrid
MEDIATOR_FORWARD_TIMEOUT=30
TRANSACTION_BODY_MAX_LENGTH=20000
ESB_REQUEST_DATA_FORMAT=json

# Database:
# - use localhost when Django runs on host machine
# - use postgres when Django runs in Docker on same compose network
DB_ENGINE=postgres
POSTGRES_DB=openhim
POSTGRES_USER=openhim
POSTGRES_PASSWORD=openhim
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_CONN_MAX_AGE=60

# RabbitMQ:
# - use localhost when Django runs on host machine
# - use rabbitmq when Django runs in Docker on same compose network
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673
RABBITMQ_URL=amqp://guest:guest@localhost:5673//
NGINX_PORT=8080

# National ESB integration
GOVESB_TOKEN_URL=
GOVESB_ENGINE_URL=
GOVESB_GRANT_TYPE=client_credentials
ESB_CLIENT_ID=
ESB_CLIENT_SECRET=
CLIENT_PRIVATE_KEY=esb_utils/signatures/privateKey.pem
CLIENT_PUBLIC_KEY=esb_utils/signatures/publicKey.pem
GOV_ESB_PUBLIC_KEY=esb_utils/signatures/publicKey.pem

# Notification SMTP
NOTIFICATION_SMTP_HOST=
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_USE_TLS=true
NOTIFICATION_SMTP_USE_SSL=false
NOTIFICATION_SMTP_TIMEOUT=15
NOTIFICATION_FROM_EMAIL=

# Notification SMS provider
NOTIFICATION_SMS_URL=
NOTIFICATION_SMS_TOKEN=
NOTIFICATION_SMS_AUTH_HEADER=
NOTIFICATION_SMS_TIMEOUT=15
NOTIFICATION_SMS_SENDER_ID=

# Branding
EMBLEM_LOGO_STATIC_PATH=branding/emblem-logo.png
EMBLEM_LOGIN_STATIC_PATH=branding/emblem-login.png
EMBLEM_ICON_STATIC_PATH=branding/emblem-icon.png
EMBLEM_FAVICON_STATIC_PATH=branding/emblem-favicon.png

# Django superuser (auto-created/updated by scripts/run_openhim.sh)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ttpb.local
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
